# Copy this file to .env and fill in values for the platforms you use.
# Do not commit .env. See README for where to get each key.

# --- Twitter/X (OAuth app required: https://developer.twitter.com/)
# TWITTER_API_CONSUMER_KEY=
# TWITTER_API_CONSUMER_SECRET=
# TWITTER_ACCESS_TOKEN_KEY=
# TWITTER_ACCESS_TOKEN_SECRET=

# --- Mastodon (create app: Development → New Application, scope write:statuses)
# https://docs.joinmastodon.org/api/oauth/
# MASTODON_HOST=mastodon.social
# MASTODON_ACCESS_TOKEN=

# --- Bluesky (use App Password, not login password: Settings → App Passwords)
# BLUESKY_IDENTIFIER=your.handle.bsky.social
# BLUESKY_PASSWORD=
# BLUESKY_HOST=bsky.social

# --- LinkedIn (OAuth token; expires after 2 months)
# https://www.linkedin.com/developers/
# LINKEDIN_ACCESS_TOKEN=

# --- Discord bot (create app at https://discord.com/developers/applications)
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=

# --- Discord webhook (server → Integrations → Webhooks)
# DISCORD_WEBHOOK_URL=

# --- Telegram (create bot via @BotFather, get chat ID via @userinfobot)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Dev.to (Settings → Extensions → DEV Community API Keys)
# DEVTO_API_KEY=

# --- Slack (create app, Bot Token Scopes: chat:write, files:write)
# SLACK_TOKEN=
# SLACK_CHANNEL=

# --- Nostr (Node.js v22+; private key hex or nsec1, relays comma-separated)
# NOSTR_PRIVATE_KEY=
# NOSTR_RELAYS=wss://relay.damus.io,wss://relay.nostr.band

# --- Reddit
# Option A: Browser (no API tokens). Run once: npm run reddit-login
# REDDIT_SUBREDDIT=your_subreddit
# REDDIT_BROWSER_AUTH_PATH=.reddit-browser-state
# Option B: API (script app at https://www.reddit.com/prefs/apps; often restricted)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
# REDDIT_SUBREDDIT=
# REDDIT_USER_AGENT=
